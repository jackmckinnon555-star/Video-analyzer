# ---- Site gate ----
# Shared password the whole team uses to access the app. Set once in Netlify env
# and GHA secrets (and on the worker if it ever needs it). No per-user accounts.
SITE_PASSWORD=change-me-to-a-long-random-string

# ---- Supabase ----
# Client-safe (ship to browser via Vite)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...
# Server-only (Netlify functions + worker)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Storage backend is Supabase Storage (bucket "videos", 5 GB per-file cap).
# No R2/S3 credentials required — everything routes through the service role key above.

# ---- GitHub Actions dispatch ----
# Fine-grained PAT with actions:write on the one repo
GITHUB_DISPATCH_TOKEN=github_pat_xxx
GITHUB_REPO=youruser/video-analyzer

# ---- Inference providers ----
GROQ_API_KEY=gsk_xxx
GEMINI_API_KEY=AIzaSy...
# Optional backup providers
CLOUDFLARE_WORKERS_AI_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ---- Failure telemetry (optional; each channel independent) ----
# Any subset can be set. Missing env = channel silently skipped.
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
ALERT_EMAIL=
RESEND_FROM=

# ---- Password rotation (optional) ----
# Accept both SITE_PASSWORD (new) and SITE_PASSWORD_PREVIOUS (old) during a
# transition window. Remove PREVIOUS once all users have the new one.
SITE_PASSWORD_PREVIOUS=

# ---- Worker config ----
# Per-chunk transcription fallback order. Each chunk walks this list until
# a backend returns a non-empty result. A mid-run failure on chunk N won't
# force earlier chunks to be re-transcribed.
TRANSCRIBE_PREFERENCE=groq,cloudflare
# Model IDs
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
