{
  "name": "tra-video-uploader",
  "productName": "TRA Video Uploader",
  "version": "0.1.0",
  "description": "Compress and upload videos to the TRA Video Analyzer.",
  "author": {
    "name": "TRA",
    "email": "jack.mckinnon555@gmail.com"
  },
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build:icon": "node scripts/make-icon.mjs",
    "build:ts": "tsc",
    "build": "npm run build:icon && npm run build:ts",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "@types/ffprobe-static": "^2.0.3",
    "@types/node": "^20.14.10",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "sharp": "^0.33.5",
    "typescript": "^5.5.4"
  }
}
